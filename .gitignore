# Claude Code local settings/session data
.claude/

# Raw & converted dataset (large binary files, not meant for git)
*.dat
*.parquet
*.zip
DroneDetect_V2_parquet/

# DuckDB summary layer: build script + generated db stay local;
# only the small exported summary parquet (~69KB) is committed
Summary_duckdb/*
!Summary_duckdb/summary.parquet
*.duckdb
*.duckdb.wal

# Long extraction/build logs (regenerable)
*_log.txt
*.log

# Large binary feature tensors (regenerable from raw parquet)
*.npy

# Trained model weights (saved locally, reproducible from fixed seeds)
*.pt

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
